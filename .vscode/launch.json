{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Cortex-Debug: STM32 OpenOCD",
            "type": "cortex-debug",
            "request": "launch",
            "servertype": "openocd",
            "cwd": "${workspaceFolder}",
            "executable": "${workspaceFolder}/build/zephyr/zephyr.elf",
            "preLaunchTask": "build",
            "gdbPath": "C:/Tools/arm-gnu-toolchain/bin/arm-none-eabi-gdb.exe",
            "serverpath": "C:/Tools/xpack-openocd-0.12.0-2/bin/openocd.exe",
            "configFiles": [
                "interface/stlink.cfg",
                "target/stm32l4x.cfg"
            ],
            "searchDir": [
                "C:/Tools/xpack-openocd-0.12.0-2/share/openocd/scripts"
            ],
            "showDevDebugOutput": "raw",
            "liveWatch": {
                "enabled": true,
                "samplesPerSecond": 4
            },
            "postLaunchCommands": [
                "monitor reset halt",
                "break main",
                "continue"
            ]
        }
    ]
}
